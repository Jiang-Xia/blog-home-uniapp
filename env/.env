VITE_APP_TITLE = 'Blog Home'
VITE_APP_PORT = 9000

VITE_UNI_APPID = '__UNI__D1E5001'
VITE_WX_APPID = 'wx1df79a9834d74211'
# 支付宝小程序 AppId（与 blog-server pay_alipayAppId 一致，RPG 充值扫码拉起用）
VITE_ALIPAY_APPID = '2021005172682351'

# h5部署网站的base，配置到 manifest.config.ts 里的 h5.router.base
VITE_APP_PUBLIC_BASE=/

# =============================================================================
# 默认 API / 静态 / 外链（与 env/.env.development 保持同一套切换规则）
# 详见 env/.env.development 注释块
# =============================================================================

# ---------- 本地直连 ----------
# VITE_SERVER_BASEURL = 'http://localhost:5000/api/v1'
# VITE_SERVER_BASEURL_SECONDARY = 'http://localhost:5000/api/v1'
# VITE_SERVER_BASEURL__WEIXIN_DEVELOP = 'http://localhost:5000/api/v1'
# VITE_SERVER_BASEURL__WEIXIN_TRIAL = 'http://localhost:5000/api/v1'
# VITE_SERVER_BASEURL__WEIXIN_RELEASE = 'http://localhost:5000/api/v1'
# VITE_WS_ORIGIN = 'http://localhost:5000'
# VITE_STATIC_BASEURL = 'http://localhost:5000'
# VITE_NUXT_HOME_URL = 'http://localhost:5050'
# VITE_ADMIN_URL = 'http://localhost:9856'

# ---------- 线上（当前默认）----------
VITE_SERVER_BASEURL = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL_SECONDARY = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL__WEIXIN_DEVELOP = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL__WEIXIN_TRIAL = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL__WEIXIN_RELEASE = 'https://jiang-xia.top/x-blog/api/v1'
VITE_WS_ORIGIN = 'https://jiang-xia.top'
VITE_STATIC_BASEURL = 'https://jiang-xia.top/x-api/blog-server'
VITE_NUXT_HOME_URL = 'https://jiang-xia.top'
VITE_ADMIN_URL = 'https://admin.jiang-xia.top'

# h5是否需要配置代理
VITE_APP_PROXY_ENABLE = false
# 下面的不用修改，只要不跟你后台的统一前缀冲突就行。如果修改了，记得修改 `nginx` 里面的配置
VITE_APP_PROXY_PREFIX = '/fg-api'

# 认证模式，'single' | 'double' ==> 单token | 双token
VITE_AUTH_MODE = 'double'

# 原生插件资源复制开关，启用后 App 构建会把根目录 nativeplugins 复制到 dist
VITE_COPY_NATIVE_RES_ENABLE = true

# 微信开发者工具 CLI 路径（pnpm dev:mp 自动打开时使用）
WECHAT_DEVTOOLS_CLI_PATH = 'D:\softwares\微信web开发者工具\cli.bat'

# 支付宝小程序开发者工具安装目录（pnpm dev:mp-alipay 自动打开时使用）
ALIPAY_DEVTOOLS_PATH = 'D:\softwares\支付宝开发者工具\小程序开发者工具'
