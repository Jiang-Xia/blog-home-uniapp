# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'production'
# 是否去除console 和 debugger
VITE_DELETE_CONSOLE = true
# 是否开启sourcemap
VITE_SHOW_SOURCEMAP = false

# =============================================================================
# 生产构建（build:mp / build:h5）— 固定走线上
# =============================================================================
VITE_SERVER_BASEURL = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL_SECONDARY = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL__WEIXIN_DEVELOP = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL__WEIXIN_TRIAL = 'https://jiang-xia.top/x-blog/api/v1'
VITE_SERVER_BASEURL__WEIXIN_RELEASE = 'https://jiang-xia.top/x-blog/api/v1'
VITE_WS_ORIGIN = 'https://jiang-xia.top'
VITE_STATIC_BASEURL = 'https://jiang-xia.top/x-api/blog-server'
VITE_NUXT_HOME_URL = 'https://jiang-xia.top'
VITE_ADMIN_URL = 'https://admin.jiang-xia.top'
