# 变量必须以 VITE_ 为前缀才能暴露给外部读取
NODE_ENV = 'development'
# 是否去除console 和 debugger
VITE_DELETE_CONSOLE = false
# 是否开启sourcemap
VITE_SHOW_SOURCEMAP = false

# =============================================================================
# 环境切换（对齐 blog-server/.env.development + blog-home-nuxt/.env.development）
# - 本地：blog-server serve_port=5000 / serve_apiPath=api/v1 / app_blogHome=5050
# - 线上：blog-home-nuxt .env.production
# 用法：启用一套、注释另一套（同一变量只保留一行有效配置）
# =============================================================================

# ---------- 本地直连（当前启用）----------
VITE_SERVER_BASEURL = 'http://localhost:5000/api/v1'
VITE_SERVER_BASEURL_SECONDARY = 'http://localhost:5000/api/v1'
VITE_SERVER_BASEURL__WEIXIN_DEVELOP = 'http://localhost:5000/api/v1'
VITE_SERVER_BASEURL__WEIXIN_TRIAL = 'http://localhost:5000/api/v1'
VITE_SERVER_BASEURL__WEIXIN_RELEASE = 'http://localhost:5000/api/v1'
VITE_WS_ORIGIN = 'http://localhost:5000'
VITE_STATIC_BASEURL = 'http://localhost:5000'
VITE_NUXT_HOME_URL = 'http://localhost:5050'
VITE_ADMIN_URL = 'http://localhost:9856'

